local start = tick()
task.spawn(function()
    while tick() - start < TOTAL_TIME do
        local elapsed = tick() - start
        local progress = elapsed / TOTAL_TIME
        local remaining = math.max(0, TOTAL_TIME - elapsed)
        
        BarFill.Size = UDim2.fromScale(progress, 1)
        ProgressPercent.Text = math.floor(progress * 100) .. "%"
        TimerLabel.Text = "ESTIMATED TIME: " .. formatTime(math.floor(remaining))
        LaunchButton.Text = "LOCKED (" .. formatTime(math.floor(remaining)) .. ")"
        
        if progress < 0.3 then
            StatusLabel.Text = "Downloading Script Modules..."
        elseif progress < 0.8 then
            StatusLabel.Text = "Injecting Bypass Hooks..."
        else
            StatusLabel.Text = "Finalizing Script Execution..."
        end
        
        if math.random(1, 15) == 1 then addLog() end
        Warning.TextTransparency = 0.2 + (math.sin(tick() * 5) * 0.2)
        task.wait(0.1)
    end
    
    canExecute = true
    StatusLabel.Text = "Bypass Ready"
    StatusLabel.TextColor3 = Color3.fromRGB(150, 255, 150)
    LaunchButton.Text = "EXECUTE SCRIPT"
    LaunchButton.TextColor3 = Color3.new(1, 1, 1)
